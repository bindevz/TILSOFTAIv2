{
  "Sql": {
    "ConnectionString": "Server=.;Database=TILSOFTAI;User ID=sa;Password=123;TrustServerCertificate=True;",
    "CommandTimeoutSeconds": 30,
    "MinPoolSize": 5,
    "MaxPoolSize": 100,
    "ConnectionTimeoutSeconds": 15,
    "ApplicationName": "TILSOFTAI"
  },
  "Redis": {
    "Enabled": true,
    "ConnectionString": "192.168.8.7:6379",
    "DefaultTtlMinutes": 30
  },
  "Auth": {
    "Enabled": false,
    "Issuer": "https://auth.tilsoft.local",
    "Audience": "tilsoftai",
    "JwksUrl": "https://auth.tilsoft.local/.well-known/jwks.json",
    "RoleClaimName": "roles",
    "ClockSkewSeconds": 300
  },
  "Chat": {
    "MaxSteps": 12,
    "MaxTokens": 4096,
    "MaxToolCallsPerRequest": 8,
    "MaxRecursiveDepth": 3,
    "CompactionLimits": {
      "ToolResultMaxBytes": 16000,
      "RetainAssistantMessages": 2
    },
    "CompactionRules": {
      "RemoveFields": [
        "CreatedAtUtc",
        "UpdatedAtUtc",
        "CreatedBy",
        "UpdatedBy"
      ],
      "MaxArrayLength": 50,
      "HeadCount": 20,
      "TailCount": 5
    }
  },
  "RuntimePolicy": {
    "Provider": "Sql",
    "Environment": "prod",
    "CacheTtlSeconds": 120
  },
  "ReAct": {
    "MaxNudgesPerTurn": 2,
    "MaxTotalNudges": 6
  },
  "Localization": {
    "DefaultLanguage": "en",
    "SupportedLanguages": [
      "en",
      "vi"
    ]
  },
  "Governance": {
    "ToolAllowlist": [],
    "ModelCallableSpPrefix": "ai_",
    "InternalSpPrefix": "app_",
    "ToolRoleRequirements": {}
  },
  "Modules": {
    "EnableLegacyAutoload": false,
    "Enabled": [
      "TILSOFTAI.Modules.Platform",
      "TILSOFTAI.Modules.Model",
      "TILSOFTAI.Modules.Analytics"
    ]
  },
  "Analytics": {
    "MaxRows": 200,
    "MaxGroupBy": 4,
    "MaxMetrics": 3,
    "MaxJoins": 1,
    "MaxTimeWindowDays": 366,
    "AllowedMetricOps": [
      "count",
      "countDistinct",
      "sum",
      "avg",
      "min",
      "max"
    ],
    "MaxPlanRetries": 2,
    "EnableTaskFramePersistence": true,
    "EnableInsightCache": true,
    "InsightCacheTtlSeconds": 300
  },
  "Observability": {
    "EnableSqlErrorLog": true,
    "EnableSqlToolLog": true,
    "EnableConversationPersistence": true,
    "RedactLogs": true,
    "RedactionMode": "basic",
    "RetentionDays": 30,
    "PurgeEnabled": false,
    "PurgeRunHourUtc": 2,
    "PurgeBatchSize": 5000
  },
  "SensitiveData": {
    "HandlingMode": "Redact",
    "DisableCachingWhenSensitive": true,
    "DisableToolResultPersistenceWhenSensitive": true
  },
  "ErrorHandling": {
    "ExposeErrorDetail": false,
    "ExposeErrorDetailRoles": [
      "ai_admin"
    ],
    "ExposeErrorDetailInDevelopment": true,
    "MaxDetailLength": 1024
  },
  "Atomic": {
    "MaxLimit": 5000,
    "MaxJoins": 3,
    "MaxTimeRangeDays": 3660
  },
  "ToolCatalogContextPack": {
    "Enabled": true,
    "MaxTools": 50,
    "MaxTotalTokens": 2000,
    "MaxInstructionTokensPerTool": 100,
    "MaxDescriptionTokensPerTool": 50
  },
  "SemanticCache": {
    "Enabled": true,
    "AllowSensitiveContent": false,
    "EnableSqlVectorCache": false
  },
  "Llm": {
    "Provider": "OpenAiCompatible",
    "Endpoint": "http://192.168.8.247:6688/v1/chat/completions",
    "ApiKey": "sk-no-key-required",
    "Model": "gemma4:26b",
    "TimeoutSeconds": 360,
    "Temperature": 0.2,
    "MaxResponseTokens": 1024
  },
  "Streaming": {
    "ChannelCapacity": 256,
    "DropDeltaWhenFull": false,
    "DeltaFlushIntervalMs": 40,
    "MaxDeltaBufferChars": 512
  },
  "Secrets": {
    "Provider": "Environment",
    "CacheSeconds": 300
  },
  "ExternalConnections": {
    "Connections": {
      "external-stock-api": {
        "BaseUrl": "https://external-stock.example.com",
        "AuthScheme": "Bearer",
        "AuthTokenSecret": "tilsoft/external-stock-api/token",
        "TimeoutSeconds": 10,
        "RetryCount": 2,
        "RetryDelayMs": 100,
        "Headers": {
          "X-Integration-System": "external-stock"
        }
      },
      "fx-rate-api": {
        "BaseUrl": "https://fx-rates.example.com",
        "ApiKeyHeader": "X-Api-Key",
        "ApiKeySecret": "tilsoft/fx-rate-api/api-key",
        "TimeoutSeconds": 10,
        "RetryCount": 2,
        "RetryDelayMs": 100
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "Enabled": true,
    "AllowedOrigins": [ "*" ],
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
    "AllowedHeaders": [ "Content-Type", "Authorization", "X-Requested-With" ],
    "AllowCredentials": false
  },
  "AllowedHosts": "*",
  "Capabilities": [
    {
      "CapabilityKey": "warehouse.inventory.summary",
      "Domain": "warehouse",
      "AdapterType": "sql",
      "Operation": "execute_query",
      "TargetSystemId": "sql",
      "ExecutionMode": "readonly",
      "RequiredRoles": [ "warehouse_read" ],
      "IntegrationBinding": {
        "storedProcedure": "dbo.ai_warehouse_inventory_summary"
      }
    },
    {
      "CapabilityKey": "warehouse.inventory.by-item",
      "Domain": "warehouse",
      "AdapterType": "sql",
      "Operation": "execute_query",
      "TargetSystemId": "sql",
      "ExecutionMode": "readonly",
      "RequiredRoles": [ "warehouse_read" ],
      "IntegrationBinding": {
        "storedProcedure": "dbo.ai_warehouse_inventory_by_item"
      },
      "ArgumentContract": {
        "RequiredArguments": [ "@ItemNo" ],
        "AllowedArguments": [ "@ItemNo", "@TenantId" ],
        "AllowAdditionalArguments": false
      }
    },
    {
      "CapabilityKey": "warehouse.receipts.recent",
      "Domain": "warehouse",
      "AdapterType": "sql",
      "Operation": "execute_query",
      "TargetSystemId": "sql",
      "ExecutionMode": "readonly",
      "RequiredRoles": [ "warehouse_read" ],
      "IntegrationBinding": {
        "storedProcedure": "dbo.ai_warehouse_receipts_recent"
      }
    },
    {
      "CapabilityKey": "warehouse.external-stock.lookup",
      "Domain": "warehouse",
      "AdapterType": "rest-json",
      "Operation": "execute_http_json",
      "TargetSystemId": "external-stock-api",
      "ExecutionMode": "readonly",
      "RequiredRoles": [ "warehouse_external_read" ],
      "IntegrationBinding": {
        "connectionName": "external-stock-api",
        "endpoint": "/warehouse/external-stock",
        "method": "GET"
      },
      "ArgumentContract": {
        "RequiredArguments": [ "@ItemNo" ],
        "AllowedArguments": [ "@ItemNo" ],
        "AllowAdditionalArguments": false
      }
    },
    {
      "CapabilityKey": "accounting.receivables.summary",
      "Domain": "accounting",
      "AdapterType": "sql",
      "Operation": "execute_query",
      "TargetSystemId": "sql",
      "ExecutionMode": "readonly",
      "RequiredRoles": [ "accounting_read" ],
      "IntegrationBinding": {
        "storedProcedure": "dbo.ai_accounting_receivables_summary"
      }
    },
    {
      "CapabilityKey": "accounting.payables.summary",
      "Domain": "accounting",
      "AdapterType": "sql",
      "Operation": "execute_query",
      "TargetSystemId": "sql",
      "ExecutionMode": "readonly",
      "RequiredRoles": [ "accounting_read" ],
      "IntegrationBinding": {
        "storedProcedure": "dbo.ai_accounting_payables_summary"
      }
    },
    {
      "CapabilityKey": "accounting.invoice.by-number",
      "Domain": "accounting",
      "AdapterType": "sql",
      "Operation": "execute_query",
      "TargetSystemId": "sql",
      "ExecutionMode": "readonly",
      "RequiredRoles": [ "accounting_read" ],
      "IntegrationBinding": {
        "storedProcedure": "dbo.ai_accounting_invoice_by_number"
      },
      "ArgumentContract": {
        "RequiredArguments": [ "@InvoiceNumber" ],
        "AllowedArguments": [ "@InvoiceNumber", "@TenantId" ],
        "AllowAdditionalArguments": false
      }
    },
    {
      "CapabilityKey": "accounting.exchange-rate.lookup",
      "Domain": "accounting",
      "AdapterType": "rest-json",
      "Operation": "execute_http_json",
      "TargetSystemId": "fx-rate-api",
      "ExecutionMode": "readonly",
      "RequiredRoles": [ "accounting_external_read" ],
      "IntegrationBinding": {
        "connectionName": "fx-rate-api",
        "endpoint": "/rates/latest",
        "method": "GET"
      },
      "ArgumentContract": {
        "RequiredArguments": [ "@CurrencyCode" ],
        "AllowedArguments": [ "@CurrencyCode" ],
        "AllowAdditionalArguments": false
      }
    }
  ]
}
